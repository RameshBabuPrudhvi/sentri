# ─── API Backend ──────────────────────────────────────────────────────────────
# Leave empty when running via Vite dev server (proxied) or Docker (nginx proxy).
# Set to the full backend URL when deploying the frontend standalone (e.g. GitHub Pages):
#   VITE_API_URL=https://your-sentri-backend.example.com
VITE_API_URL=

# ─── OAuth Client IDs (public — safe to commit) ──────────────────────────────
# These are injected at build time. The matching secrets live on the backend.
VITE_GITHUB_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
