# ─── Sentri Frontend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values you need.
# All variables are OPTIONAL — the defaults work for local development.
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# These are baked in at BUILD TIME — changes require a rebuild (`npm run build`).
# In dev mode (`npm run dev`), changes to .env are picked up on restart.

# ─── API Backend URL ─────────────────────────────────────────────────────────
# How the frontend reaches the backend API.
#
# Local dev:  Leave empty — Vite's dev proxy (vite.config.js) forwards
#             /api/* to http://localhost:3001 automatically.
# Docker:     Leave empty — nginx proxies /api → backend:3001.
# GitHub Pages / Vercel / static host:
#             Set to the full backend URL (no trailing slash):
#             VITE_API_URL=https://sentri-api.onrender.com
VITE_API_URL=

# ─── OAuth Client IDs (optional) ─────────────────────────────────────────────
# Enable "Sign in with GitHub / Google" buttons on the login page.
# Without these, only email/password authentication is available.
# These are PUBLIC client IDs (safe to commit) — the matching secrets
# are configured on the backend in backend/.env.
#
# GitHub: Create an OAuth App at https://github.com/settings/developers
#   Homepage URL:    http://localhost:3000
#   Callback URL:    http://localhost:3000/login?provider=github
VITE_GITHUB_CLIENT_ID=

# Google: Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: http://localhost:3000/login?provider=google
VITE_GOOGLE_CLIENT_ID=

# ─── GitHub Pages Deploy ─────────────────────────────────────────────────────
# Set to "true" ONLY when building for GitHub Pages (adds /sentri/ base path).
# Leave empty or unset for all other deployments.
# This is NOT a VITE_ variable — it's read by vite.config.js at build time.
# GITHUB_PAGES=true
